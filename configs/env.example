# ── env.example ──────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values, then `source .env` before
# running any scripts in this project.
# NEVER commit .env to git (it is gitignored).
# ─────────────────────────────────────────────────────────────────────────────

# ── HuggingFace ───────────────────────────────────────────────────────────────
# Optional: override where HF caches models/datasets (default: ~/.cache/huggingface)
# HF_HOME=/path/to/your/hf_cache

# ── Dataset ───────────────────────────────────────────────────────────────────
# Option A (preferred): a Hugging Face dataset repo_id under your account.
#   Format: "<hf_username>/<dataset_name>"
#   Example:
# DATASET_REPO_ID="a23v/your-dataset-name"

# Option B (fallback): path to a locally stored LeRobot-format dataset.
#   Must point to a directory that contains the LeRobot dataset files.
#   Example:
# DATASET_PATH="data/my_local_dataset"

# ── Training Output ────────────────────────────────────────────────────────────
# Where to save checkpoints and logs. Defaults to outputs/train/<timestamp> if unset.
# OUTPUT_DIR="outputs/train/my_experiment"

# ── Device ────────────────────────────────────────────────────────────────────
# Compute device for training: "cpu" | "cuda" | "cuda:0" | "mps"
# Defaults to "cpu" if unset (safe for macOS).
# DEVICE="cpu"

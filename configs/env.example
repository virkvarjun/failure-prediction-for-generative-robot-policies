# ─────────────────────────────────────────────────────────────────────────────
# configs/env.example
# Copy to configs/env (gitignored) and fill in your values.
# Source before training: source configs/env
# ─────────────────────────────────────────────────────────────────────────────

# Required: full path to your local LeRobot dataset directory.
# This is where lerobot-record stored your episodes.
# Structure must be: <root>/<owner>/<dataset_name>/ with meta/info.json inside.
# The script auto-derives dataset.repo_id and dataset.root from this path.
export DATASET_PATH="$HOME/.cache/huggingface/lerobot/a23v/failure-policy-implementation-training"

# Compute device: cpu (default) | cuda | mps
export DEVICE="cpu"

# Mini-batch size (default: 8). Lower if you hit OOM.
export BATCH_SIZE="8"

# Total training steps (default: 100000)
export MAX_STEPS="100000"

# Where to save checkpoints + logs (default: outputs/train/<timestamp>)
# export OUTPUT_DIR="outputs/train/my_experiment"

# ── Optional: Hugging Face cache location ─────────────────────────────────────
# export HF_HOME="$HOME/.cache/huggingface"

# ── Optional: Weights & Biases ────────────────────────────────────────────────
# export WANDB_API_KEY="your-key-here"
# Then set --wandb.enable=true in the train script
